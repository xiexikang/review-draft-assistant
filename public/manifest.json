{
  "manifest_version": 3,
  "name": "AI 一键评价助手",
  "version": "0.1.0",
  "description": "批量生成评价草稿并在评价页一键填入（可选一键发表）",
  "action": {
    "default_title": "AI 一键评价助手",
    "default_icon": {
      "16": "icon_16.png",
      "48": "icon_48.png",
      "128": "icon_128.png"
    }
  },
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.jd.com/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.z.ai/*",
    "https://open.bigmodel.cn/*",
    "https://openrouter.ai/*",
    "https://api.deepseek.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.minimax.chat/*",
    "https://api.moonshot.cn/*"
  ],
  "background": { "service_worker": "background/index.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://*.jd.com/*", "https://*.taobao.com/*", "https://*.tmall.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": { "default_path": "panel/index.html" }
}
